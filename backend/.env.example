PORT=5000
NODE_ENV=development
MONGODB_URI=mongodb://127.0.0.1:27017/smartface-attendance
JWT_SECRET=change-me-min-32-characters-long-secret
JWT_EXPIRE=7d
FRONTEND_URL=http://localhost:5173
ALLOW_SEED=false
ENCRYPTION_KEY=change-me-32-char-minimum-encryption-key

# Twilio: set SMS_ENABLED=true after filling SID, token, and either SMS or WhatsApp sender.
SMS_ENABLED=false
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# SMS (default)
TWILIO_MESSAGING_CHANNEL=sms
TWILIO_FROM_NUMBER=

# WhatsApp sandbox: join from phone first, then uncomment:
# TWILIO_MESSAGING_CHANNEL=whatsapp
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# SMS_DEFAULT_COUNTRY_CODE=
